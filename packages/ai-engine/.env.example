# DeltaTerminal — Environment Configuration
# Copy this file to .env and fill in your values

# ── Binance API ────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# ── Telegram Alerts (optional) ─────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Application ────────────────────────────
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ── Dashboard ──────────────────────────────
DASHBOARD_PORT=8501
DASHBOARD_HOST=localhost

# ── Risk Parameters ────────────────────────
MAX_POSITION_PCT=2.0
MAX_LEVERAGE=20
MAX_DAILY_LOSS_PCT=5.0
MAX_DRAWDOWN_PCT=10.0
RISK_PER_TRADE_PCT=1.0
